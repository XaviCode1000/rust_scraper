{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "gitnexus": {
      "type": "local",
      "command": ["gitnexus", "mcp"],
      "enabled": true,
      "timeout": 30000
    },
    "rust-scraper": {
      "type": "local",
      "command": ["cargo", "run", "--example", "mcp_server", "--quiet"],
      "enabled": true,
      "timeout": 30000
    }
  }
}
